# Copy this file to orgs/<org>/.env and fill in.
# Never commit orgs/*/.env — it's gitignored.

# --- Required -------------------------------------------------------------
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# --- Optional -------------------------------------------------------------
# GitHub token for gh CLI / private-repo clones inside the container
GH_TOKEN=

# Firewall mode: "on" (default, allowlisted) | "off" (full outbound)
FIREWALL=on

# Space- or newline-delimited extra domains to add to the allowlist when FIREWALL=on.
# Multiline:
#   EXTRA_ALLOWED_DOMAINS="registry.internal.acme.com
#   packages.acme.com"
EXTRA_ALLOWED_DOMAINS=

# IPv6 policy. Default "deny" drops all outbound IPv6 traffic (IPv4 allowlist
# is authoritative). Set to "allow" only if a workflow genuinely needs v6.
IPV6=deny

# Seconds between firewall allowlist refreshes. CDN-fronted hosts rotate A
# records; this re-resolves the allowlist periodically to stay accurate.
# Set to 0 to disable the refresh loop.
FIREWALL_REFRESH_INTERVAL=900

# Pin a specific Claude CLI version ("latest" to always pull newest)
CLAUDE_CLI_VERSION=latest

# Timezone inside the container
TZ=America/Los_Angeles

# Newline-delimited git URLs to auto-clone into /workspace on first launch.
# Idempotent: repos already present are skipped. SSH URLs require host
# ~/.ssh mounted (default on). Container exits non-zero if any clone fails.
# Example (multiline):
#   REPOS="git@github.com:me/repo-a.git
#   git@github.com:org/repo-b.git"
REPOS=

# Optional knowledge vault (e.g. Obsidian) mounted at /brain inside the
# container, read-write. Leave unset and the launcher mounts an empty scratch
# dir at ~/.claude-sandbox/empty-brain so the /brain path always exists.
#
# IMPORTANT: if your host ~/.claude/CLAUDE.md has a "Session Bootstrap" block
# that tells the agent to read /brain/maps/MOC-index.md or honor
# /brain/VAULT-RULES.md, those instructions silently no-op when BRAIN_PATH is
# unset — set this to your real vault path to actually bootstrap against it.
#
# Example: BRAIN_PATH=${HOME}/cabral-dev/brain
BRAIN_PATH=

# Override the image. Forks override to push-pull from their own GHCR namespace.
# Default resolves to ghcr.io/<owner>/claude-sandbox:latest via compose.
# Example: IMAGE=ghcr.io/myfork/claude-sandbox:v1.2.0
IMAGE=
