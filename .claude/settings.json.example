{
  "$comment": "Example sandbox-friendly Claude Code settings. Copy to ~/.claude/settings.json (merged with your host config) or adapt selectively. The file is mounted :ro at /home/node/.claude/settings.json inside every sandbox container.",

  "permissions": {
    "additionalDirectories": [
      "/workspace",
      "/brain"
    ]
  },

  "env": {
    "DISABLE_COST_WARNINGS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "60000"
  },

  "model": "claude-opus-4-7",

  "$notes": [
    "Hooks on the host don't propagate into the container (.claude/hooks is not mounted by default). Put sandbox-wide hooks in CLAUDE.md or a skill.",
    "settings.json is mounted read-only. Changes must happen on the host and take effect on next container start.",
    "`permissions.additionalDirectories` extends the writable set beyond Claude's defaults; /workspace is already cwd so this is mostly for /brain visibility."
  ]
}
