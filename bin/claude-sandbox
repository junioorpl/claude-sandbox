#!/usr/bin/env bash
# bin/claude-sandbox — one-shot Claude sandbox launcher.
# Usage: claude-sandbox <org> [service] [args...]
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

readonly ORGS_DIR="$REPO_ROOT/orgs"

readonly COLOR_RED=$'\033[0;31m'
readonly COLOR_YELLOW=$'\033[0;33m'
readonly COLOR_OFF=$'\033[0m'

log()   { printf '[claude-sandbox] %s\n' "$*"; }
warn()  { printf '%s[claude-sandbox] %s%s\n' "$COLOR_YELLOW" "$*" "$COLOR_OFF" >&2; }
err()   { printf '%s[claude-sandbox] ERROR: %s%s\n' "$COLOR_RED" "$*" "$COLOR_OFF" >&2; }
die()   { err "$*"; exit 1; }

usage() {
  cat <<'USAGE'
claude-sandbox — isolated Claude Code dev container per organization.

Usage:
  claude-sandbox <org>                    Interactive shell (ephemeral, persistent workspace volume)
  claude-sandbox <org> up                 Start persistent container (backgrounded)
  claude-sandbox <org> stop               Stop persistent container
  claude-sandbox <org> status             Show container + volume state
  claude-sandbox <org> logs               Stream container logs
  claude-sandbox <org> ide [code|cursor|codium] [--repo <name>]
                                          Open the org's container in an IDE
                                          (auto-detect: cursor → code → codium)
  claude-sandbox <org> ide-cli            Start container via devcontainer CLI (Zed / headless)
  claude-sandbox <org> throwaway          --rm + anonymous workspace volume
  claude-sandbox <org> agent <name>       Parallel instance (workspace-<org>-<name>)
  claude-sandbox <org> vscode             Generate per-org devcontainer for VS Code
  claude-sandbox --list                   List configured orgs
  claude-sandbox --build                  Rebuild local image
  claude-sandbox upgrade [version]        Upgrade shared Claude CLI volume
  claude-sandbox pull-image               Pull latest image for the configured IMAGE tag
  claude-sandbox doctor                   Diagnose image/volumes/CLI version + firewall drops
  claude-sandbox --no-host-mounts <org>   Run without host bind-mounts (hermetic)
  claude-sandbox -h | --help              Show this message
USAGE
}

validate_org_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[a-z0-9-]+$ ]]; then
    die "invalid org name '$name' — must match [a-z0-9-]+"
  fi
}

require_docker() {
  command -v docker >/dev/null || die "docker not found on PATH"
  docker info >/dev/null 2>&1 || die "docker daemon not reachable"
}

load_org_env() {
  local org="$1"
  local env_file="$ORGS_DIR/$org/.env"
  [ -f "$env_file" ] || die "missing $env_file — create it from .env.example first"
  set -a
  # shellcheck source=/dev/null
  source "$env_file"
  set +a
  export ORG="$org"
}

pre_create_host_mounts() {
  # Compose bind-mounts fail if the source path is missing.
  mkdir -p "$HOME/.claude/plugins" "$HOME/.claude/skills"
  [ -f "$HOME/.claude/settings.json" ] || echo '{}' > "$HOME/.claude/settings.json"
  [ -f "$HOME/.claude/CLAUDE.md" ] || touch "$HOME/.claude/CLAUDE.md"

  # Brain vault is optional. If BRAIN_PATH is unset/empty or points to a
  # missing dir, fall back to a shared empty dir so the compose mount always
  # has a valid source without requiring a personal path in the shared config.
  local empty_brain="$HOME/.claude-sandbox/empty-brain"
  mkdir -p "$empty_brain"
  if [ -z "${BRAIN_PATH:-}" ]; then
    export BRAIN_PATH="$empty_brain"
  elif [ ! -d "$BRAIN_PATH" ]; then
    warn "BRAIN_PATH=$BRAIN_PATH is not a directory — falling back to empty /brain mount"
    export BRAIN_PATH="$empty_brain"
  fi

  if [ ! -d "$HOME/.ssh" ]; then
    warn "no \$HOME/.ssh directory — git SSH clones inside container will fail. Use HTTPS URLs or --no-host-mounts."
  fi
}

cmd_list() {
  if [ ! -d "$ORGS_DIR" ]; then
    echo "(no orgs configured)"
    return 0
  fi
  local found=0
  for d in "$ORGS_DIR"/*/; do
    [ -d "$d" ] || continue
    local name; name="$(basename "$d")"
    [ "$name" = "." ] && continue
    if [ -f "$d/.env" ]; then
      echo "  $name"
      found=1
    fi
  done
  [ "$found" -eq 0 ] && echo "(no orgs configured — create orgs/<name>/.env)"
}

cmd_build() {
  require_docker
  log "Building image locally…"
  # Compose parses the whole file at build-time and resolves `${VAR:?}`,
  # so BRAIN_PATH must be set even for the dev service's build step.
  ORG="__build__" BRAIN_PATH="${BRAIN_PATH:-/tmp}" docker compose build dev
}

cmd_upgrade() {
  require_docker
  local version="${1:-latest}"
  log "Upgrading shared Claude CLI volume to version: $version"
  CLAUDE_CLI_VERSION="$version" ORG="__cli_init__" \
    docker compose run --rm cli-init
}

cmd_pull_image() {
  require_docker
  local image="${IMAGE:-ghcr.io/junioorpl/claude-sandbox:latest}"
  log "Pulling $image"
  docker pull "$image"
}

cmd_up() {
  require_docker
  ensure_cli_volume_populated
  pre_create_host_mounts
  log "Starting persistent container for org=$ORG"
  docker compose up -d dev
  local cid
  cid="$(docker compose ps -q dev)"
  log "Container: ${cid:0:12}  (volume: claude-data-${ORG} / workspace-${ORG})"
  log "Attach a shell:   claude-sandbox $ORG attach"
  log "Open an IDE:      claude-sandbox $ORG ide"
  log "Stop:             claude-sandbox $ORG stop"
}

cmd_stop() {
  require_docker
  log "Stopping persistent container for org=$ORG"
  docker compose stop dev
}

cmd_status() {
  require_docker
  docker compose ps
}

cmd_logs() {
  require_docker
  exec docker compose logs -f dev
}

cmd_attach() {
  require_docker
  local cid
  cid="$(docker compose ps -q dev 2>/dev/null)"
  [ -n "$cid" ] || die "no running container for org=$ORG (run: claude-sandbox $ORG up)"
  exec docker exec -it "$cid" zsh
}

detect_editor() {
  local prefer="${1:-auto}"
  if [ "$prefer" != "auto" ]; then
    command -v "$prefer" >/dev/null 2>&1 || die "editor '$prefer' not on PATH"
    echo "$prefer"
    return 0
  fi
  for cand in cursor code codium; do
    if command -v "$cand" >/dev/null 2>&1; then
      echo "$cand"
      return 0
    fi
  done
  die "no supported editor on PATH (cursor, code, codium). Install one or run: claude-sandbox $ORG ide <editor>"
}

hex_encode() {
  # Convert stdin to lowercase hex (each byte → 2 hex chars). POSIX-safe via od.
  od -A n -t x1 | tr -d ' \n'
}

cmd_ide() {
  # Parse args first so bad input fails fast (before docker/editor lookups).
  local editor="auto"
  local repo=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo) shift; repo="${1:-}"; [ -n "$repo" ] || die "--repo needs a value"; shift ;;
      code|cursor|codium) editor="$1"; shift ;;
      *) die "unknown arg for ide: $1" ;;
    esac
  done

  editor="$(detect_editor "$editor")"
  require_docker

  # Ensure container is running (idempotent — reuses existing).
  ensure_cli_volume_populated
  pre_create_host_mounts
  docker compose up -d dev

  local cid
  cid="$(docker compose ps -q dev)" || die "container not found after up"
  [ -n "$cid" ] || die "container not running"

  local target="/workspace"
  [ -n "$repo" ] && target="/workspace/$repo"

  local hex_id
  hex_id="$(printf '%s' "$cid" | hex_encode)"
  local uri="vscode-remote://attached-container+${hex_id}${target}"

  log "Opening $editor → $target (container=${cid:0:12})"
  # cursor shares VS Code's URI scheme + --folder-uri flag.
  "$editor" --folder-uri "$uri"
}

cmd_ide_cli() {
  require_docker
  command -v devcontainer >/dev/null 2>&1 || \
    die "devcontainer CLI not found. Install: npm install -g @devcontainers/cli"
  generate_vscode_devcontainer "$ORG"
  local gen_dir="$REPO_ROOT/.devcontainer/.generated/$ORG"
  pre_create_host_mounts
  log "Bringing up container via devcontainer CLI (workspace-folder=$gen_dir)"
  exec devcontainer up --workspace-folder "$gen_dir"
}

cmd_doctor() {
  require_docker
  local image="${IMAGE:-ghcr.io/junioorpl/claude-sandbox:latest}"
  local node_image="${NODE_IMAGE:-node:20-bookworm}"

  log "Image: $image"
  docker image inspect "$image" --format '  {{.Id}} ({{.Created}})' 2>/dev/null || echo "  (not pulled)"
  local local_version
  local_version="$(docker image inspect "$image" --format '{{index .Config.Labels "org.opencontainers.image.version"}}' 2>/dev/null || true)"
  if [ -n "$local_version" ] && [ "$local_version" != "<no value>" ]; then
    local channel
    case "${image##*:}" in
      latest) channel=":latest (auto-bumps)" ;;
      sha-*)  channel="pinned sha (immutable)" ;;
      v*.*.*) channel="pinned exact (immutable)" ;;
      v*.*)   channel="minor channel (auto patches)" ;;
      v*)     channel="major channel (auto minor+patch)" ;;
      *)      channel="custom" ;;
    esac
    echo "  version: $local_version ($channel)"
  fi

  log "Volumes:"
  docker volume ls --format '{{.Name}}' | grep -E '^(claude-cli-bin|claude-data-|workspace-)' | sed 's/^/  /' || true

  log "CLI version in shared volume:"
  docker run --rm -v claude-cli-bin:/opt/claude-cli --entrypoint /opt/claude-cli/bin/claude "$node_image" --version 2>/dev/null \
    || echo "  (not initialized — run: claude-sandbox upgrade)"

  log "Firewall drops (last 5 min, via dmesg):"
  # kernel log access requires CAP_SYSLOG which the container may not have;
  # fall back to the refresh log if dmesg is empty.
  local drops=""
  if command -v dmesg >/dev/null 2>&1; then
    drops="$(dmesg 2>/dev/null | grep 'fw-drop' | tail -5 || true)"
  fi
  if [ -n "$drops" ]; then
    while IFS= read -r line; do printf '  %s\n' "$line"; done <<< "$drops"
  else
    echo "  (none or log not accessible — add EXTRA_ALLOWED_DOMAINS if expected hosts are blocked)"
  fi
}

ensure_cli_volume_populated() {
  require_docker
  local node_image="${NODE_IMAGE:-node:20-bookworm}"
  if ! docker run --rm -v claude-cli-bin:/opt/claude-cli "$node_image" test -x /opt/claude-cli/bin/claude 2>/dev/null; then
    log "First-time setup: populating claude-cli-bin volume with latest CLI"
    cmd_upgrade latest
  fi
}

generate_vscode_devcontainer() {
  local org="$1"
  local out_dir="$REPO_ROOT/.devcontainer/.generated/$org"
  mkdir -p "$out_dir"
  sed "s/claude-data-default/claude-data-$org/g; \
       s/workspace-default/workspace-$org/g; \
       s/\"name\": \"Claude Sandbox (default org)\"/\"name\": \"Claude Sandbox ($org)\"/" \
    "$REPO_ROOT/.devcontainer/devcontainer.json" > "$out_dir/devcontainer.json"
  cp "$REPO_ROOT/.devcontainer/Dockerfile" "$out_dir/"
  cp "$REPO_ROOT/.devcontainer/init-firewall.sh" "$out_dir/"
  cp "$REPO_ROOT/.devcontainer/init-firewall-wrapper.sh" "$out_dir/"
}

run_service() {
  local service="$1"; shift
  local extra_args=("$@")
  ensure_cli_volume_populated
  pre_create_host_mounts
  # ${arr[@]+"${arr[@]}"} expansion is safe under set -u even when arr is empty.
  exec docker compose run --rm ${extra_args[@]+"${extra_args[@]}"} "$service"
}

main() {
  local no_host_mounts=0

  case "${1:-}" in
    -h|--help|'') usage; exit 0 ;;
    --list) cmd_list; exit 0 ;;
    --build) cmd_build; exit 0 ;;
    doctor) cmd_doctor; exit 0 ;;
    upgrade) shift; cmd_upgrade "${1:-latest}"; exit 0 ;;
    pull-image) cmd_pull_image; exit 0 ;;
    --no-host-mounts) no_host_mounts=1; shift ;;
  esac

  local org="${1:-}"
  [ -n "$org" ] || { usage; die "missing <org> argument"; }
  shift
  validate_org_name "$org"
  load_org_env "$org"

  local service="${1:-dev}"

  if [ "$no_host_mounts" -eq 1 ] && [ "$service" = "dev" ]; then
    run_service dev-hermetic
  elif [ "$no_host_mounts" -eq 1 ]; then
    die "--no-host-mounts only supported for dev service"
  fi

  case "$service" in
    dev|throwaway) shift 2>/dev/null || true; run_service "$service" ;;
    up)     shift || true; cmd_up ;;
    stop)   shift || true; cmd_stop ;;
    status) shift || true; cmd_status ;;
    logs)   shift || true; cmd_logs ;;
    attach) shift || true; cmd_attach ;;
    ide)     shift || true; cmd_ide "$@" ;;
    ide-cli) shift || true; cmd_ide_cli ;;
    agent)
      shift
      local agent_name="${1:-}"
      [ -n "$agent_name" ] || die "agent service requires a name: claude-sandbox <org> agent <name>"
      validate_org_name "$agent_name"
      export AGENT_NAME="$agent_name"
      shift || true
      run_service agent
      ;;
    vscode)
      shift || true
      generate_vscode_devcontainer "$org"
      log "Generated .devcontainer/.generated/$org/"
      log "Open in VS Code and use: Dev Containers → Reopen in Container"
      log "VS Code will use .devcontainer/.generated/$org/devcontainer.json"
      exit 0
      ;;
    *) die "unknown service '$service' (expected: dev|throwaway|agent|vscode|up|stop|status|logs|attach|ide|ide-cli)" ;;
  esac
}

main "$@"
